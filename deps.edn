{:paths ["src" "resources"]
 :deps  {org.clojure/clojure   {:mvn/version "1.12.0"}
         ;; Eido renders through the native Phane backend. Pinned by commit;
         ;; the fetched tree carries the baked native libraries, so the build
         ;; needs no Zig toolchain or Phane source checkout (clj-zig ADR 31/36).
         io.github.leifericf/eido {:git/sha "70f39a7601abaf0904f4fffffd9ad615edcb9dfd"}
         stasis/stasis         {:mvn/version "2023.11.21"}
         no.cjohansen/replicant {:mvn/version "2025.12.1"}
         garden/garden         {:mvn/version "1.3.10"}}
 :aliases
 {:dev   {:extra-paths ["dev"]
          :extra-deps  {nrepl/nrepl {:mvn/version "1.3.0"}}
          :jvm-opts ["--enable-native-access=ALL-UNNAMED"]}
  ;; The build drives the native Phane backend, so it needs FFM native access.
  :build {:exec-fn eido-site.build/build-site!
          :jvm-opts ["--enable-native-access=ALL-UNNAMED"]}}}
